# SEAM Studio — example environment configuration
#
# Copy to `.env` (or export these in your shell) to override runtime defaults.
# Every variable is OPTIONAL: with none set, the app runs fully on the Mock
# backend with the rule-based AI provider. The values shown are the built-in
# defaults — uncomment and edit only what you need to change.
#
# Naming: SEAM_* is the canonical prefix. The legacy SIONNATWIN_* names are
# still accepted for back-compat; when both are set, SEAM_* wins.
# Source of truth: backend/app/core/config.py (+ services/osm_import.py).

# --- Project discovery --------------------------------------------------------

# os.pathsep-separated list of project root directories, searched in order.
# The FIRST root is where new projects (UI imports) are created. Default is the
# built-in list: <repo>/projects (root #1) then <repo>/examples/demo_project.
# (pathsep is ';' on Windows, ':' on Linux/macOS.)
#SEAM_PROJECT_ROOTS=

# --- AI assistant (all optional; rule-based fallback needs none of these) -----

# AI gate: "auto" (use a local server if reachable), "on", or "off" (manual only).
#SEAM_AI_ENABLED=auto

# Ollama endpoint.
#SEAM_OLLAMA_URL=http://localhost:11434

# Ollama text model (per-prim + rule generation).
#SEAM_AI_TEXT_MODEL=qwen3:8b

# Ollama vision model, used only when a screenshot is attached (e.g. llava).
#SEAM_AI_VISION_MODEL=qwen2.5vl:3b

# OpenAI-compatible endpoint (e.g. LM Studio's local server).
#SEAM_OPENAI_URL=http://localhost:1234/v1

# Model id served by the OpenAI-compatible server.
#SEAM_OPENAI_MODEL=google/gemma-4-31b

# Request timeout (seconds) for text-only AI calls.
#SEAM_AI_TIMEOUT_S=60

# Request timeout (seconds) for multimodal (image-carrying) calls. A local VLM
# needs model load + multi-image prefill, so it gets a higher ceiling than text.
#SEAM_AI_VISION_TIMEOUT_S=300

# Reserved opt-in flag ("1"/"true" to enable). Parsed into settings but NO code
# acts on it in the MVP — suggestions never auto-apply.
#SEAM_AI_AUTO_APPLY=false

# --- OSM / Overpass import ----------------------------------------------------

# Overpass API endpoint used by the "import from OpenStreetMap" feature.
#SEAM_OVERPASS_URL=https://overpass-api.de/api/interpreter
