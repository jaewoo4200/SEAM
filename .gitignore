# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
# Alternate compute-engine venvs (backend/.venv-sionna-rt-122 etc.)
.venv-*/
.pytest_cache/
.mypy_cache/
dist/
build/

# Node
node_modules/
frontend/dist/
*.tsbuildinfo

# Local tooling
.tools/

# OS
.DS_Store
Thumbs.db

# Generated project outputs (examples keep their authored inputs; generated
# RF projections, results, and session provenance are reproducible at runtime)
examples/**/rf/generated_scene.xml
examples/**/rf/compile_manifest.json
examples/**/rf/meshes/
examples/**/results/
examples/**/mapping/face_group_map.json
examples/**/ai/suggestions.jsonl
examples/**/export/
# Textured overlay is a copy of the bundle GLB; regenerate via
# examples/scripts/import_bundle_scene.py --visual-overlay
examples/**/visual/overlay.glb
# Face-group split keeps a timestamped backup of the pre-split GLB next to
# the scene; it is a runtime artifact, not an authored asset.
examples/**/visual/scene.pre-split-*.glb
projects/

# Reference scene bundle (large binary assets; download separately -
# see INSTALL.md). The old personal-named dir is ignored too.
reference-bundle/
sionna-rt-gui-jaewoo-examples/

# User scene data dropped at the repo root for import testing (never ship:
# hundreds of MB of drone/photogrammetry assets + macOS zip cruft).
rf_scene/
ftc_material_segmentation_portable_*/
ftc_material_segmentation_portable_*.zip
__MACOSX/
._*

# Root-level logo drops (the committed copies live in website/assets/).
/WSL_LOGO.png
/beyond-g_logo.png

# Raw capture drops in website/assets (converted/encoded copies are committed:
# rays_demo.jpg from SEAM_pic1.png, trajectory.mp4 from the screen recording).
website/assets/SEAM_*

# Local editor/agent launch config (machine-specific paths).
.claude/

# Wheel-only bundled frontend (copied in by scripts/build_wheel.py) + build
# artifacts of the pip package.
backend/seam_studio/static/
backend/dist/
backend/*.egg-info/
