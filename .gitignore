# OS
.DS_Store
Thumbs.db

# Generated project outputs (examples keep their authored inputs; generated
# RF projections, results, and session provenance are reproducible at runtime)
examples/**/rf/generated_scene.xml
examples/**/rf/compile_manifest.json
examples/**/rf/meshes/
examples/**/results/
examples/**/mapping/face_group_map.json
examples/**/ai/suggestions.jsonl
examples/**/export/
# Textured overlay is a copy of the bundle GLB; regenerate via
# examples/scripts/import_bundle_scene.py --visual-overlay
examples/**/visual/overlay.glb
projects/

# Reference scene bundle (large binary assets; download separately -
# see INSTALL.md). The old personal-named dir is ignored too.
reference-bundle/
sionna-rt-gui-jaewoo-examples/

# Local editor/agent launch config (machine-specific paths).
.claude/
